# Database (Supabase)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_EDGE_FUNCTIONS_URL=

# Sunday Files (sunday-my Supabase project — used for workbook uploads)
REACT_APP_SUNDAY_MY_SUPABASE_URL=
REACT_APP_SUNDAY_MY_SUPABASE_ANON_KEY=

# Error tracking (Sentry)
REACT_APP_SENTRY_DSN=

# Email
REACT_APP_EMAIL_DEBUG=false

# Edge function secrets — used by Supabase functions, NOT by the React app.
# In production these are set via `supabase secrets set <key>=<value>`.
# Keep them in local .env so edge functions running locally (supabase functions serve) can read them.
GROK_API_KEY=
MAILERSEND_API_TOKEN=
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=
GOOGLE_MAPS_API_KEY=
EDGE_INTERNAL_TOKEN=
EMAIL_DEBUG_WHITELIST=

# Sentry source map upload (CI only — not needed locally)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
